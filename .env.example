# StaffySoft Portfolio — environment variables reference.
#
# Copy to `.env.local` to override values locally (`.env.local` is gitignored).
# In production these are configured as Vercel Environment Variables
# (Production + Preview) on all portfolio deploys — they are NOT read from this
# file at deploy time. This file just documents what the app looks for.
#
# The site is a static export, so only NEXT_PUBLIC_* vars are used: each value
# is inlined into the client bundle at build time.

# Base URL for StaffySoft Core's accounts app. Each product's "Add to account"
# CTA deep-links to `${NEXT_PUBLIC_STAFFYSOFT_ACCOUNTS_URL}/add?product=<id>`.
# Defaults to https://accounts.staffysoft.com (a Vercel alias for the Core
# project) when unset, so local builds work with no config.
NEXT_PUBLIC_STAFFYSOFT_ACCOUNTS_URL=https://accounts.staffysoft.com

# Optional: sub-path when hosting under a folder (e.g. the GitHub Pages project
# site at /portfolio). Leave unset for Vercel, which serves from the domain
# root. See README "Deploy → GitHub Pages".
# NEXT_PUBLIC_BASE_PATH=/portfolio
